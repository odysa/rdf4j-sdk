{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"verbatimModuleSyntax": false,
		"noEmit": false,
		"declaration": true,
		"outDir": "./dist"
	},
	"include": ["src/**/*.ts", "index.ts"],
	"exclude": ["node_modules", "dist", "**/*.test.ts"]
}
